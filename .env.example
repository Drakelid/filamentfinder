# Database
DATABASE_URL=postgresql://filamentfinder:filamentfinder@172.30.0.3:5432/filamentfinder
# For SQLite development: DATABASE_URL=sqlite:///./filamentfinder.db

# Redis (for task queue)
REDIS_URL=redis://172.30.0.4:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=f7k2m9x4p1q8w3n6v5b0j7h2g9d4s1a8
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_API_KEY=
# Development-only example key. Replace for any shared or production deployment.
CONFIG_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# Crawler, scheduling, and price-check settings are managed from the
# Configuration -> Crawler Settings page after the app is running.
# Runtime defaults still exist in the backend/worker if no DB-backed values are saved yet.

# Mullvad via Gluetun (recommended)
# Generate a WireGuard configuration file from Mullvad, then copy:
# - the PrivateKey value to MULLVAD_WIREGUARD_PRIVATE_KEY
# - the IPv4 Address value to MULLVAD_WIREGUARD_ADDRESSES, for example 10.64.x.x/32
MULLVAD_WIREGUARD_PRIVATE_KEY=
MULLVAD_WIREGUARD_ADDRESSES=
MULLVAD_SERVER_COUNTRIES=Norway,Sweden,Denmark,Finland

# Optional direct proxy mode instead of Gluetun
# Leave empty unless you have an externally reachable proxy.
# MULLVAD_SOCKS_PROXY=socks5://username:password@hostname:1080
MULLVAD_SOCKS_PROXY=

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICATION_EMAIL=

# Webhook notifications (optional)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Frontend
VITE_API_URL=http://localhost:8000
VITE_ADMIN_API_KEY=
