# Database
DATABASE_URL=postgresql://filamentfinder:filamentfinder@db:5432/filamentfinder
# For SQLite development: DATABASE_URL=sqlite:///./filamentfinder.db

# Redis (for task queue)
REDIS_URL=redis://redis:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=f7k2m9x4p1q8w3n6v5b0j7h2g9d4s1a8
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_API_KEY=
# Development-only example key. Replace for any shared or production deployment.
CONFIG_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# Crawler Configuration
CRAWLER_USER_AGENT=FilamentFinder/1.0 (+https://github.com/filamentfinder; bot)
CRAWLER_RATE_LIMIT=1.0
CRAWLER_MAX_PAGES=100
CRAWLER_MAX_DEPTH=3
CRAWLER_TIMEOUT=30
CRAWLER_RESPECT_ROBOTS_TXT=true

# Scheduler Configuration
SCAN_SCHEDULE_ENABLED=true
SCAN_SCHEDULE_CRON=0 6 * * *

# VPN / Proxy
# Mullvad removed OpenVPN on January 15, 2026. Use WireGuard values instead.
# Generate a Mullvad WireGuard configuration, then copy the private key and IPv4 address/CIDR.
MULLVAD_WIREGUARD_PRIVATE_KEY=
MULLVAD_WIREGUARD_ADDRESSES=
MULLVAD_SERVER_COUNTRIES=Sweden

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICATION_EMAIL=

# Webhook notifications (optional)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Frontend
VITE_API_URL=http://localhost:8000
VITE_ADMIN_API_KEY=
